{
  "manifest_version": 3,
  "name": "Workaholic",
  "version": "1.0.0",
  "description": "Filters freelance jobs from multiple platforms based on your skill profile",

  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "https://www.upwork.com/*",
    "https://www.workana.com/*",
    "https://www.99freelas.com.br/*",
    "https://www.linkedin.com/*",
    "https://br.indeed.com/*",
    "https://*.gupy.io/*",
    "https://www.gupy.io/*",
    "https://portal.gupy.io/*"
  ],

  "background": {
    "scripts": [
      "libs/browser-polyfill.js",
      "shared/storage.js",
      "shared/normalizer.js",
      "shared/filter.js",
      "background/service-worker.js"
    ],
    "service_worker": "background/service-worker.js"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "workaholic@local",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["parsers/*.parser.js"],
      "matches": [
        "https://www.upwork.com/*",
        "https://www.workana.com/*",
        "https://www.99freelas.com.br/*",
        "https://www.linkedin.com/*",
        "https://br.indeed.com/*",
        "https://*.gupy.io/*",
        "https://www.gupy.io/*",
        "https://portal.gupy.io/*"
      ]
    },
    {
      "resources": ["libs/pdf.worker.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
