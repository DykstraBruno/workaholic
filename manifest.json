{
  "manifest_version": 3,
  "name": "Workaholic",
  "version": "1.0.0",
  "description": "Filters freelance jobs from multiple platforms based on your skill profile",

  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "https://www.upwork.com/*",
    "https://www.workana.com/*",
    "https://www.99freelas.com.br/*",
    "https://www.linkedin.com/*",
    "https://br.indeed.com/*",
    "https://*.gupy.io/*",
    "https://www.gupy.io/*",
    "https://portal.gupy.io/*",
    "https://www.freelancer.com/*",
    "https://weworkremotely.com/*",
    "https://www.peopleperhour.com/*",
    "https://www.guru.com/*"
  ],

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon128.png",
      "32": "icons/icon128.png",
      "48": "icons/icon128.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon128.png",
    "32": "icons/icon128.png",
    "48": "icons/icon128.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["parsers/*.parser.js"],
      "matches": [
        "https://www.upwork.com/*",
        "https://www.workana.com/*",
        "https://www.99freelas.com.br/*",
        "https://www.linkedin.com/*",
        "https://br.indeed.com/*",
        "https://*.gupy.io/*",
        "https://www.gupy.io/*",
        "https://portal.gupy.io/*",
        "https://www.freelancer.com/*",
        "https://weworkremotely.com/*",
        "https://www.peopleperhour.com/*",
        "https://www.guru.com/*"
      ]
    },
    {
      "resources": ["libs/pdf.worker.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
